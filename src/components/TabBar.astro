---
/**
 * Program launcher tabs — run CLI programs without full page reload.
 * data-cmd is picked up by Terminal (prototerm:run event).
 */
const pathname = Astro.url.pathname;

const tabs = [
  {
    href: "/",
    label: "portfolio",
    cmd: "portfolio",
    match: (p: string) => p === "/",
  },
  {
    href: "/markets",
    label: "markets",
    cmd: "markets",
    match: (p: string) => p.startsWith("/markets"),
  },
  {
    href: "/crypto",
    label: "crypto",
    cmd: "crypto ls",
    match: (p: string) => p.startsWith("/crypto"),
  },
  {
    href: "/stocks",
    label: "stocks",
    cmd: "stocks ls",
    match: (p: string) => p.startsWith("/stocks"),
  },
];
---

<nav class="tabbar" aria-label="Programs" id="tabbar">
  <div class="tabs">
    {
      tabs.map((tab) => {
        const active = tab.match(pathname);
        return (
          <a
            href={tab.href}
            class:list={["tab", { "is-active": active }]}
            data-cmd={tab.cmd}
            aria-current={active ? "page" : undefined}
          >
            <span class="tab-bracket">[</span>
            {tab.label}
            <span class="tab-bracket">]</span>
          </a>
        );
      })
    }
  </div>
  <div class="tab-hint dim" title="CLI programs">
    bin: portfolio markets crypto stocks
  </div>
</nav>

<style>
  .tabbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 0 0.35rem;
    background: var(--chrome);
    border-bottom: 1px solid var(--border);
    position: relative;
    z-index: 2;
    overflow-x: auto;
    flex-shrink: 0;
  }

  .tabs {
    display: flex;
    align-items: stretch;
    min-width: 0;
  }

  .tab {
    padding: 0.5rem 0.75rem;
    font-size: 0.8rem;
    color: var(--text-dim);
    border-bottom: 2px solid transparent;
    white-space: nowrap;
    transition: color 0.12s ease, border-color 0.12s ease, background 0.12s ease;
    cursor: pointer;
  }

  .tab:hover {
    color: var(--text);
    background: rgba(77, 141, 255, 0.06);
  }

  .tab.is-active {
    color: var(--blue);
    border-bottom-color: var(--red);
    background: linear-gradient(
      180deg,
      rgba(77, 141, 255, 0.1),
      rgba(255, 77, 109, 0.06)
    );
  }

  .tab-bracket {
    opacity: 0.45;
  }

  .tab.is-active .tab-bracket {
    opacity: 0.8;
  }

  .tab-hint {
    font-size: 0.7rem;
    padding-right: 0.5rem;
    flex-shrink: 0;
    display: none;
  }

  @media (min-width: 720px) {
    .tab-hint {
      display: block;
    }
  }
</style>

<script>
  function bindTabs() {
    const bar = document.getElementById("tabbar");
    if (!bar || bar.dataset.bound === "1") return;
    bar.dataset.bound = "1";

    bar.querySelectorAll<HTMLAnchorElement>("a[data-cmd]").forEach((link) => {
      link.addEventListener("click", (e) => {
        // Same-origin SPA-ish: if terminal is on the page, run program in-place
        const terminal = document.getElementById("terminal");
        const cmd = link.dataset.cmd;
        if (terminal && cmd) {
          e.preventDefault();
          bar.querySelectorAll(".tab").forEach((t) => t.classList.remove("is-active"));
          link.classList.add("is-active");
          window.dispatchEvent(
            new CustomEvent("prototerm:run", { detail: cmd }),
          );
          // Keep URL shareable without full reload when possible
          const href = link.getAttribute("href");
          if (href && window.location.pathname !== href) {
            history.pushState({ cmd }, "", href);
          }
        }
      });
    });
  }

  bindTabs();
  document.addEventListener("astro:page-load", bindTabs);
</script>
