---
const pathname = Astro.url.pathname;

const tabs = [
  { href: "/", label: "portfolio", match: (p: string) => p === "/" },
  {
    href: "/markets",
    label: "markets",
    match: (p: string) => p === "/markets" || p.startsWith("/markets/"),
  },
  {
    href: "/crypto",
    label: "crypto",
    match: (p: string) => p === "/crypto" || p.startsWith("/crypto/"),
  },
  {
    href: "/stocks",
    label: "stocks",
    match: (p: string) => p === "/stocks" || p.startsWith("/stocks/"),
  },
];
---

<nav class="tabbar" aria-label="Views">
  <div class="tabs">
    {
      tabs.map((tab) => {
        const active = tab.match(pathname);
        return (
          <a
            href={tab.href}
            class:list={["tab", { "is-active": active }]}
            aria-current={active ? "page" : undefined}
          >
            <span class="tab-bracket">[</span>
            {tab.label}
            <span class="tab-bracket">]</span>
          </a>
        );
      })
    }
  </div>
  <div class="tab-hint dim" title="Tipp: unten command eingeben">
    help | ls | goto …
  </div>
</nav>

<style>
  .tabbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 0 0.35rem;
    background: var(--chrome);
    border-bottom: 1px solid var(--border);
    position: relative;
    z-index: 2;
    overflow-x: auto;
  }

  .tabs {
    display: flex;
    align-items: stretch;
    min-width: 0;
  }

  .tab {
    padding: 0.5rem 0.75rem;
    font-size: 0.8rem;
    color: var(--text-dim);
    border-bottom: 2px solid transparent;
    white-space: nowrap;
    transition: color 0.12s ease, border-color 0.12s ease, background 0.12s ease;
  }

  .tab:hover {
    color: var(--text);
    background: rgba(51, 255, 102, 0.04);
  }

  .tab.is-active {
    color: var(--green);
    border-bottom-color: var(--green);
    background: rgba(51, 255, 102, 0.06);
  }

  .tab-bracket {
    opacity: 0.45;
  }

  .tab.is-active .tab-bracket {
    opacity: 0.8;
  }

  .tab-hint {
    font-size: 0.7rem;
    padding-right: 0.5rem;
    flex-shrink: 0;
    display: none;
  }

  @media (min-width: 720px) {
    .tab-hint {
      display: block;
    }
  }
</style>
