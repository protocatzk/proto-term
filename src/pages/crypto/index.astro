---
import BaseLayout from "../../layouts/BaseLayout.astro";
import AssetTable from "../../components/AssetTable.astro";
import SearchFilter from "../../components/SearchFilter.astro";
import { cryptoAssets } from "../../data/crypto";
---

<BaseLayout
  title="Crypto"
  windowTitle="prototerm — crypto"
  description="Crypto-Markt im CLI-Style — Mock-Daten."
>
  <p class="cli-line">
    <span class="dim">$</span> <span class="bright">crypto ls --sort mcap</span>
  </p>
  <p class="cli-line dim cli-block">
    # {cryptoAssets.length} assets · mock prices · type: crypto btc
  </p>

  <SearchFilter targetId="crypto-table" placeholder="grep btc|ethereum…" />
  <AssetTable assets={cryptoAssets} id="crypto-table" showRank />
</BaseLayout>
