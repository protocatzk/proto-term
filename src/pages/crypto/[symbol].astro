---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Terminal from "../../components/Terminal.astro";
import { cryptoAssets } from "../../data/crypto";
import type { GetStaticPaths } from "astro";

export const getStaticPaths = (() => {
  return cryptoAssets.map((asset) => ({
    params: { symbol: asset.symbol.toLowerCase() },
    props: { symbol: asset.symbol.toLowerCase() },
  }));
}) satisfies GetStaticPaths;

const { symbol } = Astro.props;
---

<BaseLayout
  title={`crypto ${symbol}`}
  windowTitle={`prototerm — crypto/${symbol}`}
  description={`crypto show ${symbol}`}
>
  <Terminal initialCommand={`crypto show ${symbol}`} />
</BaseLayout>
