---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Terminal from "../../components/Terminal.astro";
import { stockAssets } from "../../data/stocks";
import type { GetStaticPaths } from "astro";

export const getStaticPaths = (() => {
  return stockAssets.map((asset) => ({
    params: { symbol: asset.symbol.toLowerCase() },
    props: { symbol: asset.symbol.toLowerCase() },
  }));
}) satisfies GetStaticPaths;

const { symbol } = Astro.props;
---

<BaseLayout
  title={`stocks ${symbol}`}
  windowTitle={`prototerm — stocks/${symbol}`}
  description={`stocks show ${symbol}`}
>
  <Terminal initialCommand={`stocks show ${symbol}`} />
</BaseLayout>
